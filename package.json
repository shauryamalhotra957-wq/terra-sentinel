{
  "name": "terra-sentinel",
  "private": true,
  "version": "1.0.0",
  "description": "A humanitarian risk command center for disaster lifelines, resource allocation, and public warnings.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "node scripts/build-pages.mjs",
    "lint": "oxlint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "qa:visual": "node scripts/visual-qa.mjs",
    "preview:pages": "node scripts/pages-preview.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run test && npm run build && npm run security:audit",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
